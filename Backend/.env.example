# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/smart-financial-planning
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart-financial-planning?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Anthropic / Claude API ───────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-your-key-here
